                {
                  "atomType": "Molecule",
                  "x": 0.38227513227513227,
                  "y": 0.836111111111111,
                  "uniqueID": "id-36644",
                  "name": "Shaft Gear",
                  "topLevel": false,
                  "allAtoms": [
                    {
                      "atomType": "Output",
                      "x": 0.98,
                      "y": 0.5,
                      "uniqueID": "id-36645",
                      "ioValues": [
                        {
                          "name": "number or geometry",
                          "ioValue": "__GEOMETRY_INPUT__"
                        }
                      ]
                    },
                    {
                      "atomType": "Extrude",
                      "x": 0.47160068846815834,
                      "y": 0.5083333333333333,
                      "uniqueID": "id-36646",
                      "ioValues": [
                        {
                          "name": "geometry",
